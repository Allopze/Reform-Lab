# ── Reform Lab — Docker Compose production environment ──
# Copy this file to .env at the repo root before running `docker compose up -d --build`.

# Public endpoints exposed only to the local reverse proxy on the host.
WEB_BIND_ADDRESS=127.0.0.1
WEB_HOST_PORT=5050
API_BIND_ADDRESS=127.0.0.1
API_HOST_PORT=8080

# Public URLs used by the browser and by backend-generated links.
# Recommended production shape: reverse proxy with TLS in front of both services.
CORS_ORIGIN=https://YOUR_SERVER_OR_DOMAIN
NEXT_PUBLIC_API_URL=https://YOUR_SERVER_OR_DOMAIN
# Internal URL used by the Next.js container to proxy same-origin /api/* calls.
INTERNAL_API_URL=http://api:8080
# Optional metadata override for standalone web builds; APP_URL is enough for the root compose stack.
NEXT_PUBLIC_APP_URL=
APP_URL=https://YOUR_SERVER_OR_DOMAIN

# Runtime mode
APP_ENV=production
LOG_LEVEL=info
# Keep true only when requests always arrive through your trusted reverse proxy.
TRUST_PROXY_HEADERS=true

# Required secrets
# NOTE: placeholders are intentionally invalid so you must replace them.
# Generate a strong JWT secret (>= 32 chars), e.g.:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-in-production

# Secret encryption key used to encrypt stored secrets (32 raw bytes, or base64 for 32 bytes).
# Generate a base64 key, e.g.:
#   python3 -c "import base64,secrets; print(base64.b64encode(secrets.token_bytes(32)).decode())"
SECRET_ENCRYPTION_KEY=

# Queue / worker
REDIS_URL=redis://redis:6379
WORKER_CONCURRENCY=2

# Rate limits and quotas
USER_UPLOADS_PER_MINUTE=12
USER_UPLOAD_BURST=4
USER_CONVERSIONS_PER_MINUTE=6
USER_CONVERSION_BURST=3
MAX_ACTIVE_JOBS_PER_USER=3
MAX_ACTIVE_JOBS_PER_GUEST_SESSION=1
GUEST_CUMULATIVE_QUOTA_BYTES=26214400
REGISTERED_CUMULATIVE_QUOTA_BYTES=524288000

# Retention
ORIGINAL_RETENTION_HOURS=24
TEMP_RETENTION_HOURS=6
ARTIFACT_TTL_HOURS=24
ARTIFACT_TTL_HOURS_PDF=48
ARTIFACT_TTL_HOURS_IMAGE=12
ARTIFACT_TTL_HOURS_DOCUMENT=24
ARTIFACT_TTL_HOURS_AUDIO=72
ARTIFACT_TTL_HOURS_VIDEO=96

# Metrics
# METRICS_TOKEN is required by the API when EXPOSE_METRICS=true in production.
EXPOSE_METRICS=false
METRICS_TOKEN=

# Optional bootstrap restriction for the first admin claim.
# If empty, the first registered account becomes the initial admin.
# Operational note: create that first admin before exposing the app publicly,
# or restrict this list to trusted operator emails.
BOOTSTRAP_ADMIN_EMAILS=

# Optional verified-email gate for sensitive authenticated mutations.
# Keep false until SMTP/email verification is working for your admins.
REQUIRE_VERIFIED_EMAIL_FOR_SENSITIVE_ACTIONS=false

# Optional feature flags
FEATURE_DISABLE_CAPABILITIES=
FEATURE_DISABLE_ENGINES=

# Optional SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
SMTP_USE_TLS=true

# Optional OpenTelemetry export
OTEL_EXPORTER_OTLP_ENDPOINT=

# Optional Sentry values forwarded to the frontend build.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# Optional container resource limits
API_MEMORY_LIMIT=1024m
API_CPUS=1.00
REDIS_MEMORY_LIMIT=512m
WORKER_MEMORY_LIMIT=2048m
WORKER_CPUS=2.00
