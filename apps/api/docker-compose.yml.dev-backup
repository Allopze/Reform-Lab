# Development docker-compose — uses in-process embedded worker by default.
# For production, use the redis profile with the production overlay:
#   docker compose --profile redis -f docker-compose.yml -f docker-compose.production.yml up -d
# The API will refuse to start in production mode without REDIS_URL set.

services:
  # Redis is optional. Remove or comment out if not needed.
  redis:
    image: redis:7-alpine
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 5s
      timeout: 3s
      retries: 5
    networks:
      - worker_internal
    profiles:
      - redis

  api:
    build:
      context: .
      dockerfile: Dockerfile
    init: true
    ports:
      - "${API_BIND_ADDRESS:-127.0.0.1}:8080:8080"
    environment:
      APP_ENV: "${APP_ENV:-development}"
      PORT: "8080"
      DATABASE_PATH: "/data/reform.db"
      MIGRATIONS_PATH: "/app/migrations"
      STORAGE_BASE_PATH: "/data"
      CORS_ORIGIN: "http://localhost:3000"
      LOG_LEVEL: "debug"
      JWT_SECRET: "${JWT_SECRET:?JWT_SECRET must be set to a strong value}"
      EXPOSE_METRICS: "${EXPOSE_METRICS:-false}"
      METRICS_TOKEN: "${METRICS_TOKEN:-}"
      TRUST_PROXY_HEADERS: "${TRUST_PROXY_HEADERS:-false}"
      IN_PROCESS_WORKER_CONCURRENCY: "${IN_PROCESS_WORKER_CONCURRENCY:-2}"
      WORKER_CONCURRENCY: "${WORKER_CONCURRENCY:-2}"
      ORIGINAL_RETENTION_HOURS: "${ORIGINAL_RETENTION_HOURS:-24}"
      TEMP_RETENTION_HOURS: "${TEMP_RETENTION_HOURS:-6}"
      ARTIFACT_TTL_HOURS: "${ARTIFACT_TTL_HOURS:-24}"
      ARTIFACT_TTL_HOURS_PDF: "${ARTIFACT_TTL_HOURS_PDF:-48}"
      ARTIFACT_TTL_HOURS_IMAGE: "${ARTIFACT_TTL_HOURS_IMAGE:-12}"
      ARTIFACT_TTL_HOURS_DOCUMENT: "${ARTIFACT_TTL_HOURS_DOCUMENT:-24}"
      ARTIFACT_TTL_HOURS_AUDIO: "${ARTIFACT_TTL_HOURS_AUDIO:-72}"
      ARTIFACT_TTL_HOURS_VIDEO: "${ARTIFACT_TTL_HOURS_VIDEO:-96}"
      FEATURE_DISABLE_CAPABILITIES: "${FEATURE_DISABLE_CAPABILITIES:-}"
      FEATURE_DISABLE_ENGINES: "${FEATURE_DISABLE_ENGINES:-}"
      # Uncomment to use Redis queue instead of in-process:
      # REDIS_URL: "redis://redis:6379"
    volumes:
      - storage:/data
    read_only: true
    tmpfs:
      - /tmp:size=268435456,mode=1777
      - /run:size=16777216,mode=755
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    pids_limit: 256
    mem_limit: 1024m
    cpus: 1.00
    networks:
      - public
      - worker_internal

  # Standalone worker — only needed when using Redis queue.
  worker:
    build:
      context: .
      dockerfile: Dockerfile.worker
    init: true
    environment:
      APP_ENV: "${APP_ENV:-development}"
      DATABASE_PATH: "/data/reform.db"
      MIGRATIONS_PATH: "/app/migrations"
      REDIS_URL: "redis://redis:6379"
      STORAGE_BASE_PATH: "/data"
      LOG_LEVEL: "debug"
      JWT_SECRET: "${JWT_SECRET:?JWT_SECRET must be set to a strong value}"
      WORKER_CONCURRENCY: "${WORKER_CONCURRENCY:-2}"
      ORIGINAL_RETENTION_HOURS: "${ORIGINAL_RETENTION_HOURS:-24}"
      TEMP_RETENTION_HOURS: "${TEMP_RETENTION_HOURS:-6}"
      ARTIFACT_TTL_HOURS: "${ARTIFACT_TTL_HOURS:-24}"
      ARTIFACT_TTL_HOURS_PDF: "${ARTIFACT_TTL_HOURS_PDF:-48}"
      ARTIFACT_TTL_HOURS_IMAGE: "${ARTIFACT_TTL_HOURS_IMAGE:-12}"
      ARTIFACT_TTL_HOURS_DOCUMENT: "${ARTIFACT_TTL_HOURS_DOCUMENT:-24}"
      ARTIFACT_TTL_HOURS_AUDIO: "${ARTIFACT_TTL_HOURS_AUDIO:-72}"
      ARTIFACT_TTL_HOURS_VIDEO: "${ARTIFACT_TTL_HOURS_VIDEO:-96}"
      FEATURE_DISABLE_CAPABILITIES: "${FEATURE_DISABLE_CAPABILITIES:-}"
      FEATURE_DISABLE_ENGINES: "${FEATURE_DISABLE_ENGINES:-}"
    volumes:
      - storage:/data
    read_only: true
    tmpfs:
      - /tmp:size=536870912,mode=1777
      - /run:size=16777216,mode=755
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    pids_limit: 512
    mem_limit: 2048m
    cpus: 2.00
    networks:
      - worker_internal
    depends_on:
      redis:
        condition: service_healthy
    profiles:
      - redis

volumes:
  storage:

networks:
  public:
  worker_internal:
    internal: true
