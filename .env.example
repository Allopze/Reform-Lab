# ── Reform Lab — Environment Variables ──
# Copy this file to .env at the repo root.
# This is the canonical env file for `npm run dev`.

# Go API
APP_ENV=development
API_BIND_ADDRESS=127.0.0.1
PORT=4040
DATABASE_PATH=./data/reform.db
MIGRATIONS_PATH=./migrations
STORAGE_BASE_PATH=./data
CORS_ORIGIN=http://localhost:5050,http://127.0.0.1:5050
LOG_LEVEL=debug

# Redis (required when APP_ENV=production)
REDIS_URL=

# Optional: only these emails may claim the initial admin bootstrap in production.
BOOTSTRAP_ADMIN_EMAILS=

# JWT secret must be at least 32 chars and cannot use the banned placeholders.
JWT_SECRET=replace-this-with-a-long-local-jwt-secret-123456
MAX_ACTIVE_JOBS_PER_GUEST_SESSION=1

# Exposure / proxy
EXPOSE_METRICS=false
METRICS_TOKEN=
TRUST_PROXY_HEADERS=false

# Worker concurrency
IN_PROCESS_WORKER_CONCURRENCY=2
WORKER_CONCURRENCY=2

# Upload and conversion quotas
USER_UPLOADS_PER_MINUTE=12
USER_UPLOAD_BURST=4
USER_CONVERSIONS_PER_MINUTE=6
USER_CONVERSION_BURST=3
MAX_ACTIVE_JOBS_PER_USER=3
GUEST_CUMULATIVE_QUOTA_BYTES=26214400
REGISTERED_CUMULATIVE_QUOTA_BYTES=524288000

# Original and temp cleanup
ORIGINAL_RETENTION_HOURS=24
TEMP_RETENTION_HOURS=6

# Artifact retention (hours)
ARTIFACT_TTL_HOURS=24
ARTIFACT_TTL_HOURS_PDF=48
ARTIFACT_TTL_HOURS_IMAGE=12
ARTIFACT_TTL_HOURS_DOCUMENT=24
ARTIFACT_TTL_HOURS_AUDIO=72
ARTIFACT_TTL_HOURS_VIDEO=96

# Feature flags (comma-separated)
FEATURE_DISABLE_CAPABILITIES=
FEATURE_DISABLE_ENGINES=

# Public app URL used by email links; defaults to CORS_ORIGIN when empty.
APP_URL=http://localhost:5050

# Optional SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
SMTP_USE_TLS=true

# Optional OpenTelemetry export
OTEL_EXPORTER_OTLP_ENDPOINT=

# Next.js and optional Sentry
NEXT_PUBLIC_API_URL=http://localhost:4040
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
